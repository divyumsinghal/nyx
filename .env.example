# =============================================================================
# .env.example — Nyx environment variables reference
# Copy to .env and fill in real values.  NEVER commit .env to git.
#
# Sections:
#   1.  PostgreSQL
#   2.  DragonflyDB (cache / rate limiting / sessions)
#   3.  NATS JetStream (event bus)
#   4.  MinIO (object storage)
#   5.  Meilisearch (full-text search)
#   6.  Ory Kratos (identity & auth)
#   7.  Continuwuity / Matrix (DMs)
#   8.  Gorush (push notifications)
#   9.  JWT (inter-service)
#   10. SMTP (email delivery)
#   11. SMS — Twilio (phone verification OTP)
#   12. Observability (OTLP, Prometheus, Loki, Grafana)
#   13. Deployment & gateway (ports, image tags)
#   14. Frontend (SvelteKit build-time vars)
#
# Production secret generation:
#   openssl rand -base64 32    →  43-char base64 string (good for most secrets)
#   openssl rand -hex 32       →  64-char hex string
#
# DOMAIN LAYOUT (change for your environment):
#   DEV:  everything on localhost, HTTP
#   PROD: nyx.com (account portal), uzume.nyx.com (Uzume), auth.nyx.com (Kratos)
#         matrix.nyx.com (Matrix), grafana.nyx.com (internal monitoring)
# =============================================================================

# ── 1. PostgreSQL ─────────────────────────────────────────────────────────────
# Root superuser: only used by docker-entrypoint-initdb.d/ scripts.
# Application code must NEVER use this credential.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_ROOT_PASSWORD=changeme_root_never_used_by_app

# Application role: SELECT/INSERT/UPDATE/DELETE only (no DDL).
# Used by all microservices at runtime.
NYX_APP_DB_PASSWORD=changeme_app

# Migration role: CREATE TABLE / ALTER TABLE / DROP TABLE.
# Used exclusively by nyx-xtask (just db-migrate, just db-reset).
NYX_MIGRATION_DB_PASSWORD=changeme_migration

# Constructed DSNs (not stored here; assembled in service env blocks):
#   App:       postgres://nyx_app:${NYX_APP_DB_PASSWORD}@${POSTGRES_HOST}:5432/nyx
#   Migration: postgres://nyx_migration:${NYX_MIGRATION_DB_PASSWORD}@${POSTGRES_HOST}:5432/nyx
#   Kratos:    postgres://kratos_app:${KRATOS_DB_PASSWORD}@${POSTGRES_HOST}:5432/kratos

# ── 2. DragonflyDB ────────────────────────────────────────────────────────────
# Redis-protocol cache. DB index allocation:
#   0 — application cache (Lethe: session cache, feed cache, rate limiting)
#   1 — Gorush push queue persistence
#   2 — Gorush push stats
DRAGONFLY_PORT=6379
DRAGONFLY_PASSWORD=changeme_dragonfly
# Constructed URL: redis://:${DRAGONFLY_PASSWORD}@localhost:${DRAGONFLY_PORT}

# ── 3. NATS JetStream ─────────────────────────────────────────────────────────
# Streams (created by nyx-xtask at startup, not baked into nats-server.conf):
#   NYX   — subjects: nyx.>   (nyx.user.created, nyx.user.deleted)
#   UZUME — subjects: Uzume.> (Uzume.post.created, Uzume.story.viewed, …)
NATS_CLIENT_PORT=4222
NATS_MONITOR_PORT=8222
NYX_NATS_USER=nyx
NYX_NATS_PASSWORD=changeme_nats
# Constructed URL: nats://${NYX_NATS_USER}:${NYX_NATS_PASSWORD}@localhost:${NATS_CLIENT_PORT}

# ── 4. MinIO (object storage) ─────────────────────────────────────────────────
# Single bucket: nyx-media
# Path convention: {app}/{entity}/{post_id}/{variant}.{ext}
#   e.g. uzume/posts/01924c6b-…/full.webp
#        uzume/reels/01924c6b-…/master.m3u8
#
# PROD: point MINIO_ENDPOINT to Cloudflare R2 (zero egress costs):
#   MINIO_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   MINIO_ACCESS_KEY=<R2 access key>
#   MINIO_SECRET_KEY=<R2 secret key>
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=nyx-minio-admin
MINIO_ROOT_PASSWORD=changeme_minio_root
# Prometheus scrape token — generate with: mc admin prometheus generate local
MINIO_PROMETHEUS_TOKEN=changeme_minio_prometheus_token

# ── 5. Meilisearch ────────────────────────────────────────────────────────────
# Indexes managed by Brizo crate:
#   Uzume_posts, Uzume_profiles, Uzume_reels, Uzume_audio
MEILI_PORT=7700
# Master key: minimum 16 characters. Generate: openssl rand -base64 32
MEILI_MASTER_KEY=changeme_meili_master_key_at_least_16_chars
# 'development' enables the Meilisearch dashboard UI (disable in prod).
# DEV:  development
# PROD: production
MEILI_ENV=development

# ── 6. Ory Kratos (identity & auth) ──────────────────────────────────────────
# Identity model:
#   Signup:  email + phone + username + password (all required)
#   Login:   email OR phone OR username + password
#   Verify:  email (magic link/OTP) + phone (SMS OTP via Twilio)
#   Recover: email OTP
#
# PROD domain changes:
#   KRATOS_PUBLIC_URL  →  https://auth.nyx.com
#   COOKIE_DOMAIN      →  nyx.com   (covers all *.nyx.com subdomains)
#   SESSION_COOKIE_SECURE → true
KRATOS_DB_PASSWORD=changeme_kratos_db
KRATOS_PUBLIC_PORT=4433
KRATOS_ADMIN_PORT=4434
KRATOS_PUBLIC_URL=http://localhost:4433

# Cookie & cipher secrets — MUST be exactly 32 bytes, MUST be different from each other.
# Generate: openssl rand -base64 32
KRATOS_COOKIE_SECRET=changeme_cookie_secret_32bytes_xxxx
KRATOS_CIPHER_SECRET=changeme_cipher_secret_32bytes_yyyy

# Cookie domain: 'localhost' in dev; 'nyx.com' in prod.
COOKIE_DOMAIN=localhost
# Set 'true' in prod (HTTPS-only cookie flag).
SESSION_COOKIE_SECURE=false

# ── 7. Continuwuity / Matrix (DMs & group chat) ───────────────────────────────
# ⚠ server_name is PERMANENT — baked into all Matrix IDs on first start.
#   Changing it later requires a full database wipe.
#   DEV:  use 'localhost' or a local domain (e.g. nyx.local)
#   PROD: use 'nyx.com'  →  Matrix IDs will be @alice:nyx.com
#
# Federation is disabled by default (privacy-first). To enable:
#   Set allow_federation = true in Prithvi/config/continuwuity/conduwuit.toml
MATRIX_PORT=8008
MATRIX_SERVER_NAME=nyx.com
# Log level: 'warn' for prod, 'warn,conduwuit=info' for debug
CONDUWUIT_LOG=warn

# ── 8. Gorush (push notifications — APNs + FCM) ───────────────────────────────
GORUSH_PORT=8088
# API key: Ushas sends 'Authorization: Bearer <key>' to Gorush HTTP API.
# Generate: openssl rand -base64 32
GORUSH_API_KEY=changeme_gorush_api_key

# iOS APNs — token-based auth (.p8 key file)
# Obtain from: https://developer.apple.com/account/resources/authkeys/list
# Mount the key file into the Gorush container via volume in prod.yml.
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID_UZUME=com.nyx.uzume

# Android FCM (HTTP v1 API — legacy key deprecated 2024-07-22)
# Obtain from: Firebase Console → Project Settings → Cloud Messaging
FCM_API_KEY=

# ── 9. JWT (inter-service auth) ───────────────────────────────────────────────
# Heimdall signs short-lived JWTs for downstream service calls.
# This is NOT the Kratos session token — Kratos manages its own session cookies.
# Generate: openssl rand -base64 64
JWT_SECRET=changeme_jwt_secret_generate_with_openssl_rand_base64_64
JWT_EXPIRY_SECONDS=3600

# ── 10. SMTP (email delivery) ─────────────────────────────────────────────────
# Kratos uses this to send: verification emails, recovery codes, login codes.
#
# DEV — Mailhog (started automatically by dev.yml, no configuration needed):
SMTP_CONNECTION_URI=smtp://mailhog:1025/?skip_ssl_verify=true
SMTP_FROM_ADDRESS=noreply@nyx.com
#
# PROD examples (uncomment one and set credentials):
#
# Mailgun:
#   SMTP_CONNECTION_URI=smtps://postmaster%40mg.nyx.com:MAILGUN_SMTP_PASSWORD@smtp.mailgun.org:465/
#
# Postmark:
#   SMTP_CONNECTION_URI=smtps://POSTMARK_API_TOKEN:POSTMARK_API_TOKEN@smtp.postmarkapp.com:465/
#
# AWS SES (us-east-1):
#   SMTP_CONNECTION_URI=smtps://AKIAIOSFODNN7EXAMPLE:SECRET@email-smtp.us-east-1.amazonaws.com:465/

# ── 11. SMS / Twilio (phone number verification OTP) ─────────────────────────
# Required for phone verification at signup and passwordless SMS login.
# DEV: leave blank — Kratos SMS courier will log the OTP instead of sending it.
#   To test locally: check Kratos container logs for the OTP code.
# Obtain from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# A purchased Twilio phone number in E.164 format: +15551234567
TWILIO_PHONE_NUMBER=

# ── 12. Observability ─────────────────────────────────────────────────────────
# OpenTelemetry (traces): Rust services export spans via OTLP to this endpoint.
# In prod: point to Grafana Tempo or Jaeger.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

PROMETHEUS_PORT=9090
LOKI_PORT=3100
# Grafana is served on 3030 to avoid collision with app services on 3000–3005.
GRAFANA_PORT=3030
GRAFANA_ROOT_URL=http://localhost:3030
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana
# DEV: allow anonymous viewer access (makes local dashboard exploration easy).
# PROD: set to 'false' — require login.
GRAFANA_ANON=true
# Passed to Prometheus external_labels for dashboard filtering.
ENVIRONMENT=dev

# ── 13. Deployment & gateway ──────────────────────────────────────────────────
# Service port bindings (change if you have port conflicts locally).
HEIMDALL_PORT=3000
UZUME_PROFILES_PORT=3001
UZUME_FEED_PORT=3002
UZUME_STORIES_PORT=3003
UZUME_REELS_PORT=3004
UZUME_DISCOVER_PORT=3005

# Docker image tag used in platform.yml / uzume.yml.
# CI sets this to the git SHA on release builds.
NYX_VERSION=latest

# Rust tracing-subscriber log filter.
# Format: comma-separated directives, e.g. "warn,sqlx=info,axum=debug"
# DEV:  debug,hyper=info,sqlx=warn
# PROD: warn
RUST_LOG=warn

# ── 14. Frontend — SvelteKit build-time vars ──────────────────────────────────
# These are NOT runtime env vars — they are baked into the JS bundle at
# docker build time via --build-arg PUBLIC_API_BASE_URL=...
# They must start with PUBLIC_ to be visible in the browser (SvelteKit convention).
#
# Set these as --build-arg in Dockerfile.web / GitHub Actions, not here.
# Listed here for documentation only.
#
# PUBLIC_API_BASE_URL   — Heimdall gateway URL
#   DEV:  http://localhost:3000/api
#   PROD: https://nyx.com/api
#
# PUBLIC_KRATOS_URL     — Kratos public API URL (browser-facing)
#   DEV:  http://localhost:4433
#   PROD: https://auth.nyx.com
#
# NX_WEB_URL is a server-side variable used by Kratos for redirect URLs.
NX_WEB_URL=http://localhost:5173
