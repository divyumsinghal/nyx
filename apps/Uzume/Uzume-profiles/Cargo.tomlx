[package]
name = "uzume-profiles"
version = "0.1.0"
edition = "2024"

[lib]
name = "uzume_profiles"
path = "src/lib.rs"

[workspace]
members = []

[dependencies]
nun = { package = "Nun", path = "../../../Monad/Nun" }
heka = { package = "Heka", path = "../../../Monad/Heka" }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
