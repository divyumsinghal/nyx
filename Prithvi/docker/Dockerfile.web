# =============================================================================
# Dockerfile.web — SvelteKit frontend → nginx
# Builds a SvelteKit app and serves the output via nginx.
#
# Build args:
#   APP_DIR        — relative path within Maya/ (e.g. "Uzume-web", "nyx-web")
#   PUBLIC_API_BASE_URL — baked into the JS bundle at build time
#
# Usage:
#   docker build \
#     --build-arg APP_DIR=Uzume-web \
#     --build-arg PUBLIC_API_BASE_URL=https://nyx.com/api \
#     -f Prithvi/docker/Dockerfile.web \
#     -t ghcr.io/divyumsinghal/nyx/uzume-web:latest \
#     .
#
# CHANGE FOR PRODUCTION:
#   - Set PUBLIC_API_BASE_URL to your gateway URL
#   - Set PUBLIC_KRATOS_URL to your Kratos public URL
#   - Tune nginx worker_processes + worker_connections for your vCPU count
# =============================================================================

# syntax=docker/dockerfile:1.7

# ── Stage 1: Node.js build ────────────────────────────────────────────────────
FROM node:22-alpine AS builder

ARG APP_DIR
ARG PUBLIC_API_BASE_URL=/api
ARG PUBLIC_KRATOS_URL=http://localhost:4433

WORKDIR /build

# Install pnpm via corepack (ships with Node 22)
RUN corepack enable && corepack prepare pnpm@latest --activate

# Install all workspace dependencies (cached layer)
COPY package.json pnpm-workspace.yaml ./
COPY Maya/ ./Maya/

RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile

# Build the target app
WORKDIR /build/Maya/${APP_DIR}

ENV PUBLIC_API_BASE_URL=${PUBLIC_API_BASE_URL}
ENV PUBLIC_KRATOS_URL=${PUBLIC_KRATOS_URL}
ENV NODE_ENV=production

RUN pnpm build

# ── Stage 2: nginx runtime ────────────────────────────────────────────────────
FROM nginx:1.27-alpine AS runtime

ARG APP_DIR

# Copy built static assets
COPY --from=builder /build/Maya/${APP_DIR}/build /usr/share/nginx/html

# Copy nginx site config (SPA routing: all 404s → index.html)
COPY Prithvi/docker/nginx-spa.conf /etc/nginx/conf.d/default.conf

# Remove default nginx config
RUN rm -f /etc/nginx/conf.d/default.conf.default

# nginx runs as 'nginx' user by default in the official image
EXPOSE 8080

HEALTHCHECK --interval=10s --timeout=5s --retries=3 \
    CMD wget -qO- http://localhost:8080/ || exit 1
