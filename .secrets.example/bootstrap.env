# =============================================================================
# .secrets/bootstrap.env — Bootstrap secrets (copy to .secrets/bootstrap.env)
#
# These are the ONLY secrets that cannot live in Infisical because they are
# needed to start postgres, dragonfly, and Infisical itself.
#
# HOW TO USE:
#   cp .secrets.example/bootstrap.env .secrets/bootstrap.env
#   <fill in real values>
#   # Never commit .secrets/ — it is gitignored.
#
# GENERATE RANDOM VALUES:
#   openssl rand -hex 32      → 64-char hex (use for passwords)
#   openssl rand -base64 16   → 16-byte base64 (use for INFISICAL_ENCRYPTION_KEY)
#   openssl rand -base64 32   → 32-byte base64 (use for INFISICAL_AUTH_SECRET)
# =============================================================================

# ── PostgreSQL root ────────────────────────────────────────────────────────────
POSTGRES_ROOT_PASSWORD=change_me_postgres_root

# ── Application DB roles (set once at first postgres start — permanent) ────────
NYX_APP_DB_PASSWORD=change_me_nyx_app
NYX_MIGRATION_DB_PASSWORD=change_me_nyx_migration
KRATOS_DB_PASSWORD=change_me_kratos

# ── DragonflyDB (Redis-protocol cache) ────────────────────────────────────────
DRAGONFLY_PASSWORD=change_me_dragonfly

# ── Infisical self-hosted (secrets manager) ───────────────────────────────────
# DB password for Infisical's own PostgreSQL user (set once at first postgres start)
INFISICAL_DB_PASSWORD=change_me_infisical_db

# 16-byte hex key: openssl rand -hex 16
INFISICAL_ENCRYPTION_KEY=change_me_16_byte_hex_key_here_xx

# JWT secret for Infisical's internal auth: openssl rand -base64 32
INFISICAL_AUTH_SECRET=change_me_infisical_auth_secret_base64
