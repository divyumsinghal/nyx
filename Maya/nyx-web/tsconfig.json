{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "module": "ESNext",
    "baseUrl": ".",
    "paths": {
      "@nyx/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@nyx/ui/*": [
        "../../packages/ui/src/*"
      ],
      "@nyx/api": [
        "../../packages/api/src/index.ts"
      ],
      "@nyx/api/*": [
        "../../packages/api/src/*"
      ],
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}
